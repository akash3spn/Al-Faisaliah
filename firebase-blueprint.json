{
  "entities": {
    "User": {
      "title": "User",
      "description": "Store users and admins",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "eCommerce product at Al-Faisaliah Store",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "isFeatured": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "description", "category", "price", "stock", "images", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "slug", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingAddress", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["productId", "userId", "userName", "rating", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stored user profiles"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Store categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders over time"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews on products"
    }
  }
}
