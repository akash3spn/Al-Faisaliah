rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'product_manager', 'order_manager', 'inventory_manager', 'customer_support', 'content_manager']; 
    }
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.role is string
        && data.createdAt is int;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'price', 'stock', 'images', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200 && data.title.size() > 0
        && data.description is string && data.description.size() <= 5000
        && data.category is string && data.category.size() <= 100
        && data.price is number && data.price >= 0
        && data.stock is number && data.stock >= 0
        && data.images is list && data.images.size() <= 10 && (data.images.size() == 0 || data.images[0] is string)
        && data.createdAt is int
        && data.updatedAt is int;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'status', 'createdAt'])
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.status is string && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
        && data.createdAt is int;
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUser(incoming()) 
        && incoming().createdAt <= request.time.toMillis() + 60000
        && incoming().createdAt >= request.time.toMillis() - 60000
        && incoming().role in ['user', 'super_admin']; // Allow demo super_admin creation
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) && incoming().displayName is string && incoming().displayName.size() <= 100)
          || isSuperAdmin()
        );
      allow delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Public list and get
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt <= request.time.toMillis() + 60000 && incoming().updatedAt <= request.time.toMillis() + 60000;
      allow update: if isAdmin() && isValidProduct(incoming()) && incoming().updatedAt <= request.time.toMillis() + 60000 && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() 
        && incoming().keys().hasAll(['name', 'slug', 'image', 'createdAt'])
        && incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100
        && incoming().slug is string && incoming().slug.size() > 0 && incoming().slug.size() <= 100
        && incoming().image is string && incoming().image.size() <= 500
        && incoming().createdAt <= request.time.toMillis() + 60000;
      allow update: if isAdmin(); // simplified for space
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && ((resource.data.userId != null && resource.data.userId == request.auth.uid) || isAdmin());
      allow create: if isValidOrder(incoming()) && incoming().createdAt <= request.time.toMillis() + 60000 && incoming().status == 'pending';
      allow update: if isAdmin(); // only admin updates order status
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true; // public reviews
      allow create: if isSignedIn() 
        && incoming().keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt'])
        && incoming().userId == request.auth.uid
        && incoming().productId is string && incoming().productId.size() > 0
        && incoming().userName is string && incoming().userName.size() <= 100
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().comment is string && incoming().comment.size() <= 1000
        && incoming().createdAt <= request.time.toMillis() + 60000
        && exists(/databases/$(database)/documents/products/$(incoming().productId));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /discount_codes/{discountId} {
      allow read: if true;
      allow create: if isAdmin() && incoming().keys().hasAll(['code', 'type', 'value', 'active'])
        && incoming().code is string && incoming().code.size() > 0 && incoming().code.size() <= 50
        && incoming().type is string && incoming().type in ['percentage', 'fixed']
        && incoming().value is number && incoming().value >= 0
        && incoming().active is bool;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
